INCIDENTECHO_PORT=8080
INCIDENTECHO_DATABASE_PASSWORD=incidentecho
INCIDENTECHO_DATABASE_URL=postgresql+asyncpg://incidentecho:incidentecho@localhost:5432/incidentecho
INCIDENTECHO_ANALYSIS_CATALOG_LIMIT=1000
INCIDENTECHO_GITHUB_WEBHOOK_SECRET=replace-with-a-random-secret
INCIDENTECHO_GITHUB_APP_ID=replace-with-the-numeric-app-id
# Keep the real key only in .env or a deployment secret store. Escaped newlines are supported.
INCIDENTECHO_GITHUB_APP_PRIVATE_KEY=replace-with-the-private-key-pem
