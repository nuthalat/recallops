RECALLOPS_PORT=8080
RECALLOPS_DATABASE_PASSWORD=recallops
RECALLOPS_DATABASE_URL=postgresql+asyncpg://recallops:recallops@localhost:5432/recallops
RECALLOPS_ANALYSIS_CATALOG_LIMIT=1000
RECALLOPS_GITHUB_WEBHOOK_SECRET=replace-with-a-random-secret
RECALLOPS_GITHUB_APP_ID=replace-with-the-numeric-app-id
# Keep the real key only in .env or a deployment secret store. Escaped newlines are supported.
RECALLOPS_GITHUB_APP_PRIVATE_KEY=replace-with-the-private-key-pem
